generator client {
  provider   = "prisma-client-js"
  output     = "../generated/prisma"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  userId           Int       @id @default(autoincrement()) @map("user_id")
  email            String    @unique
  password         String
  organisationName String    @map("organisation_name")
  products         Product[]
  settings         Settings?
}

model Product {
  productId         Int      @id @default(autoincrement()) @map("product_id")
  user              User     @relation(fields: [organizationId], references: [userId])
  organizationId    Int      @map("organization_id")
  name              String
  sku               String
  description       String?
  quantityOnHand    Int      @default(0) @map("quantity_on_hand")
  costPrice         Decimal? @map("cost_price") @db.Decimal(12, 2)
  sellingPrice      Decimal? @map("selling_price") @db.Decimal(12, 2)
  lowStockThreshold Int?     @map("low_stock_threshold")
  isActive          Boolean  @default(true) @map("is_active")
  isFeatured        Boolean  @default(false) @map("is_featured")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")
  category          Category @relation(fields: [categoryName], references: [category])
  categoryName      String   @default("electronic") @map("category_name")
  fileUrl           String   @default("\\dummyfile") @map("file_url")
  selectedSizes     Json     @default("[]") @map("selected_sizes")

  @@unique([organizationId, sku])
  @@index([organizationId])
}

model Category {
  categoryId Int       @id @default(autoincrement()) @map("category_id")
  category   String    @unique
  product    Product[]
}

model Settings {
  settingsId               Int  @id @default(autoincrement()) @map("settings_id")
  organizationId           Int  @unique @map("organization_id")
  defaultLowStockThreshold Int? @map("default_low_stock_threshold")
  organization             User @relation(fields: [organizationId], references: [userId])
}
